# Copie este arquivo para .env e preencha os valores reais
# Nao comite o arquivo .env com segredos

MART_URL=https://mart.dacorp.net.br
MART_BEARER_TOKEN=seu_token_bearer
MART_XSRF_TOKEN=seu_token_xsrf
MART_CONN_STR=TRC=NO;SRV=mart.dacorp.net.br;PRT=443;ASR=MartServer;SSL=YES;UID=<User>;PSW=<sua_senha>

# Opcional: se vazio, exporta todos os modelos
# Formato: MM/DD/YYYY
# Use uma das opcoes:
# 1) Data exata (nao combinar com MIN/MAX)
MART_UPDATED_ON_EXACT=

# 2) Minima (>=)
MART_UPDATED_ON_MIN=03/11/2026

# 3) Maxima (<=) - pode combinar com MIN para formar intervalo
MART_UPDATED_ON_MAX=
